programa {
  funcao inicio() {
       inteiro idade = 18
        real altura = 1.83
        cadeia nome = "Andrey"
        caracter inicial = 'A'
        logico estuda = verdadeiro

        escreva("Idade: ", idade, "\n")
        escreva("Altura: ", altura, "\n")
        escreva("Nome: ", nome, "\n")
        escreva("Inicial: ", inicial, "\n")
        escreva("Estuda: ", estuda, "\n")
  }
}
